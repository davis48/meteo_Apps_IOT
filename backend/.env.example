PORT=3002
MYSQL_EMBEDDED=true
MYSQL_EMBEDDED_VERSION=8.4.x
MYSQL_EMBEDDED_DBNAME=meteo_iot
MYSQL_EMBEDDED_PORT=3307
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=meteo_iot
SIMULATION_INTERVAL_MS=10000

# ─── MQTT Broker ────────────────────────────────────────────────
# Mettre MQTT_ENABLED=false pour désactiver
MQTT_ENABLED=true

# URL du broker Mosquitto
# mqtt://localhost:1883          → local sans TLS
# mqtts://mon-serveur.com:8883   → distant avec TLS
MQTT_URL=mqtt://localhost:1883

# Identifiants broker (laisser vide si pas d'auth)
MQTT_USER=meteo_user
MQTT_PASS=meteo_pass
